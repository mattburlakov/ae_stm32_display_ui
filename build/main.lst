 194:Src/main.c    **** static void write_char(const uint8_t x_pos, const uint8_t y_pos, const uint32_t *Char) {
 195:Src/main.c    **** 
 196:Src/main.c    ****     uint8_t char_pos = 0;
 197:Src/main.c    ****     // Выводим символ
 198:Src/main.c    ****     for(uint8_t i=0;i<8;i++) {
 199:Src/main.c    ****         uint16_t pos = (256/4)*(7-i+y_pos)+(256/4-x_pos);
 200:Src/main.c    ****         OLED_Data[pos+1].DataW = Char[char_pos]>>16;
 201:Src/main.c    ****         OLED_Data[pos].DataW = Char[char_pos++];
 202:Src/main.c    ****     }
 203:Src/main.c    **** }
