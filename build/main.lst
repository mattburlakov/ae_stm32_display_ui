 229:Src/main.c    **** static void write_char(const uint8_t x_pos, const uint8_t y_pos, const uint32_t *Char) {
 230:Src/main.c    ****     uint8_t char_pos = 0;
 231:Src/main.c    ****     // ąÆčŗą▓ąŠą┤ąĖą╝ čüąĖą╝ą▓ąŠą╗
 232:Src/main.c    ****     for(uint8_t i=0;i<8;i++) {// i - symbol height
 233:Src/main.c    ****         uint16_t pos = (256/4)*(7-i+y_pos)+(256/4-x_pos);
 234:Src/main.c    ****         OLED_Data[pos+1].DataW = Char[char_pos]>>16;
