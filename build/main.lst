 110:Src/main.c    **** static uint8_t *u8x8_ssd1322_8to32(U8X8_UNUSED u8x8_t *u8x8, uint8_t *ptr)
 111:Src/main.c    **** {
 112:Src/main.c    ****   uint8_t v;
 113:Src/main.c    ****   uint8_t a,b;
 114:Src/main.c    ****   uint8_t i, j;
 115:Src/main.c    ****   uint8_t *dest;
 116:Src/main.c    **** 
 117:Src/main.c    ****   for( j = 0; j < 4; j++ )
 118:Src/main.c    ****   {
 119:Src/main.c    ****     dest = u8x8_ssd1322_to32_dest_buf;
 120:Src/main.c    ****     dest += j;
 121:Src/main.c    ****     a =*ptr;
 122:Src/main.c    ****     ptr++;
 123:Src/main.c    ****     b = *ptr;
 124:Src/main.c    ****     ptr++;
 125:Src/main.c    ****     for( i = 0; i < 8; i++ )
 126:Src/main.c    ****     {
 127:Src/main.c    ****       v = 0;
 128:Src/main.c    ****       if ( a&1 ) v |= 0xf0;
 129:Src/main.c    ****       if ( b&1 ) v |= 0x0f;
 130:Src/main.c    ****       *dest = v;
 131:Src/main.c    ****       dest+=4;
 132:Src/main.c    ****       a >>= 1;
 133:Src/main.c    ****       b >>= 1;
 134:Src/main.c    ****     }
