 151:Src/main.c    **** 
 152:Src/main.c    ****   for( j = 0; j < 4; j++ )
 153:Src/main.c    ****   {
 154:Src/main.c    ****     dest = u8x8_ssd1322_to32_dest_buf;
 155:Src/main.c    ****     dest += j;
 156:Src/main.c    ****     a =*ptr;
